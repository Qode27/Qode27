{
  "name": "kansalt-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "dev:kansalt-frontend": "npm run dev -w @kansalt/kansalt-frontend",
    "dev:api-gateway": "npm run dev -w @kansalt/api-gateway",
    "dev:auth-service": "npm run dev -w @kansalt/auth-service",
    "dev:hms-service": "npm run dev -w @kansalt/hms-service",
    "dev:hrms-service": "npm run dev -w @kansalt/hrms-service",
    "dev:user-service": "npm run dev -w @kansalt/user-service",
    "dev:app-service": "npm run dev -w @kansalt/app-service",
    "dev:billing-service": "npm run dev -w @kansalt/billing-service",
    "dev:notification-service": "npm run dev -w @kansalt/notification-service",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate -w @kansalt/prisma",
    "lint": "npm run lint --workspaces --if-present"
  }
}
