        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* HERO SECTION */
    .hero {
        position: relative;
        overflow: hidden;
        padding: 7rem 2rem;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.5) 0%, rgba(30, 58, 95, 0.3) 100%);
        text-align: center;
        min-height: 700px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(at 20% 50%, rgba(59, 130, 246, 0.15) 0px, transparent 50%),
            radial-gradient(at 80% 50%, rgba(251, 191, 36, 0.1) 0px, transparent 50%);
        animation: gradient-pulse 8s ease-in-out infinite;
        pointer-events: none;
    }

    @keyframes gradient-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.8; }
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 900px;
        animation: fade-up-intro 0.8s ease-out;
    }

    @keyframes fade-up-intro {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .hero h1 {
        background: linear-gradient(135deg, #f1f5f9 0%, #cbd5e1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1rem;
    }

    .hero-accent {
        background: linear-gradient(135deg, #60a5fa 0%, #fbbf24 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.3rem;
        color: #cbd5e1;
        margin-bottom: 2rem;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.7;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2.5rem;
    }

    .btn-hero {
        padding: 1rem 2.5rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .btn-primary-hero {
        background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
        color: white;
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
    }

    .btn-primary-hero:hover {
        transform: translateY(-4px);
        box-shadow: 0 15px 50px rgba(59, 130, 246, 0.5);
        background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
    }

    .btn-secondary-hero {
        background: rgba(251, 191, 36, 0.1);
        color: #fbbf24;
        border: 2px solid #fbbf24;
        backdrop-filter: blur(10px);
    }

    .btn-secondary-hero:hover {
        background: rgba(251, 191, 36, 0.2);
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(251, 191, 36, 0.2);
    }

    /* SECTION STYLING */
    .section {
        max-width: 1400px;
        margin: 0 auto;
        padding: 5rem 2rem;
    }

    .section-title {
        text-align: center;
        margin-bottom: 1rem;
    }

    .section-subtitle {
        text-align: center;
        color: #cbd5e1;
        font-size: 1.1rem;
        margin-bottom: 3rem;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }

    /* CARDS & GRID */
    .card {
        background: rgba(30, 58, 95, 0.5);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(251, 191, 36, 0.15);
        border-radius: 15px;
        padding: 2rem;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .card:hover {
        border-color: rgba(251, 191, 36, 0.4);
        background: rgba(30, 58, 95, 0.8);
        box-shadow: 0 20px 50px rgba(59, 130, 246, 0.15);
        transform: translateY(-8px);
    }

    .card-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        display: inline-block;
        animation: float-icon 4s ease-in-out infinite;
    }

    @keyframes float-icon {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }

    .card-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fbbf24;
        margin-bottom: 0.75rem;
    }

    .card-text {
        color: #cbd5e1;
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    /* STEPS */
    .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .step {
        position: relative;
        padding: 2.5rem;
        background: rgba(30, 58, 95, 0.4);
        border-radius: 12px;
        border: 1px solid rgba(251, 191, 36, 0.1);
        transition: all 0.3s ease;
    }

    .step:hover {
        background: rgba(30, 58, 95, 0.7);
        border-color: #fbbf24;
        transform: translateY(-5px);
    }

    .step-num {
        position: absolute;
        top: -18px;
        left: 25px;
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #3b82f6 0%, #fbbf24 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        color: white;
        font-size: 1.4rem;
        box-shadow: 0 5px 20px rgba(59, 130, 246, 0.3);
    }

    .step-title {
        font-weight: 700;
        color: #fbbf24;
        margin-top: 1.2rem;
        margin-bottom: 0.75rem;
    }

    .step-text {
        color: #cbd5e1;
        line-height: 1.6;
        font-size: 0.95rem;
    }

    /* BENEFITS */
    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .benefit {
        display: flex;
        gap: 1.5rem;
        padding: 2rem;
        background: rgba(30, 58, 95, 0.3);
        border-radius: 12px;
        border-left: 4px solid #fbbf24;
        transition: all 0.3s ease;
    }

    .benefit:hover {
        background: rgba(30, 58, 95, 0.6);
        transform: translateX(8px);
        box-shadow: 0 10px 30px rgba(251, 191, 36, 0.1);
    }

    .benefit-icon {
        font-size: 2.5rem;
        min-width: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .benefit-title {
        font-weight: 700;
        color: #fbbf24;
        margin-bottom: 0.25rem;
    }

    .benefit-text {
        color: #cbd5e1;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* FOOTER */
    .footer {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(30, 58, 95, 0.4) 100%);
        border-top: 1px solid rgba(251, 191, 36, 0.15);
        padding: 4rem 2rem 2rem;
        margin-top: 6rem;
    }

    .footer-grid {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2.5rem;
        margin-bottom: 2.5rem;
    }

    .footer-col h4 {
        color: #fbbf24;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .footer-col a {
        display: block;
        color: #cbd5e1;
        margin: 0.5rem 0;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }

    .footer-col a:hover {
        color: #fbbf24;
    }

    .footer-bottom {
        max-width: 1400px;
        margin: 0 auto;
        text-align: center;
        padding-top: 2rem;
        border-top: 1px solid rgba(251, 191, 36, 0.1);
        color: #94a3b8;
        font-size: 0.85rem;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        h1 { font-size: 2rem !important; }
        h2 { font-size: 1.5rem !important; }
        .hero { padding: 3rem 1rem; min-height: 500px; }
        .cta-buttons { flex-direction: column; }
        .btn-hero { width: 100%; }
        .section { padding: 3rem 1rem; }
    }

    /* UTILITY */
    .text-center { text-align: center; }
    .max-width { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }
</style>
""", unsafe_allow_html=True)

