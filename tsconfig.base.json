{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@kansalt/prisma": [
        "shared/prisma/src"
      ],
      "@kansalt/utils": [
        "shared/utils/src"
      ],
      "@kansalt/middleware": [
        "shared/middleware/src"
      ]
    }
  }
}
